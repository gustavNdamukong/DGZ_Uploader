# Keep the Composer "dist" download lean — exclude non-runtime files from
# installs. These still live in the git repo (e.g. the README logo shows on
# GitHub/Packagist), but they won't be shipped into anyone's vendor/ folder.
/assets/         export-ignore
/.gitattributes  export-ignore
/.gitignore      export-ignore
/phpunit.xml     export-ignore
/tests/          export-ignore
/.phpunit.result.cache export-ignore
